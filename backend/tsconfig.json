{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs", //Node.js 전통 방식, Express + ts-node 조합에서 안정적
    "lib": ["ES2020"],
    "outDir": "./dist", // 빌드 결과물 위치 지정
    "rootDir": "./src", // 소스 파일 위치 지정
    "strict": true,
    "esModuleInterop": true, // import/require 방식 혼용 허용 (Express 등에서 필요)
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
